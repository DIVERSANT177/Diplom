<%# app/views/analyses/_result_clustering.html.erb %>
<% result = analysis.result %>

<div class="row mb-4">
  <div class="col-md-4">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-3 fw-bold text-primary"><%= result["n_clusters"] %></div>
        <div class="text-muted small"><%= t("analyses.show.n_clusters") %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-3 fw-bold text-primary"><%= result["silhouette_score"] %></div>
        <div class="text-muted small"><%= t("analyses.show.silhouette_score") %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-center">
      <div class="card-body">
        <div class="fs-3 fw-bold text-primary"><%= result["n_cases"] %></div>
        <div class="text-muted small"><%= t("analyses.show.n_cases") %></div>
      </div>
    </div>
  </div>
</div>

<%# Таблица статистики по кластерам %>
<div class="card mb-4">
  <div class="card-header"><%= t("analyses.show.cluster_stats") %></div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th><%= t("analyses.show.cluster") %></th>
          <th><%= t("analyses.show.n_patients") %></th>
          <th><%= t("analyses.show.n_dead") %></th>
          <th><%= t("analyses.show.mortality_rate") %></th>
          <th><%= t("analyses.show.median_age") %></th>
          <th><%= t("analyses.show.median_survival") %></th>
        </tr>
      </thead>
      <tbody>
        <% result["cluster_stats"].each do |stat| %>
          <tr>
            <td><span class="badge bg-primary">Cluster <%= stat["cluster"] %></span></td>
            <td><%= stat["n_patients"] %></td>
            <td><%= stat["n_dead"] %></td>
            <td><%= "#{(stat["mortality_rate"] * 100).round(1)}%" %></td>
            <td><%= stat["median_age"] || "—" %></td>
            <td><%= stat["median_survival"] ? "#{stat["median_survival"].round(0)} days" : "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# График распределения пациентов по кластерам %>
<div class="card mb-4">
  <div class="card-header"><%= t("analyses.show.cluster_distribution") %></div>
  <div class="card-body">
    <div id="clusterChart" style="height: 400px;"></div>
  </div>
</div>

<script>
  (() => {
    const stats = <%= result["cluster_stats"].to_json.html_safe %>;
    const colors = ["#6366f1", "#f472b6", "#22c55e", "#f59e0b", "#06b6d4"];

    Plotly.newPlot("clusterChart", [{
      type: "bar",
      x: stats.map(s => `Cluster ${s.cluster}`),
      y: stats.map(s => s.n_patients),
      marker: { color: stats.map((_, i) => colors[i % colors.length]) },
      text: stats.map(s => `${(s.mortality_rate * 100).toFixed(1)}% mortality`),
      textposition: "outside",
      hovertemplate: "<b>Cluster %{x}</b><br>Patients: %{y}<br>%{text}<extra></extra>"
    }], {
      xaxis: { title: "<%= t('analyses.show.cluster') %>" },
      yaxis: { title: "<%= t('analyses.show.n_patients') %>" },
      margin: { t: 40 }
    });
  })();
</script>
