<%= form_with(model: dashboard) do |form| %>
  <% if dashboard.errors.any? %>
    <div style="color: red">
      <h2><%= t('common.errors', count: dashboard.errors.count) %></h2>
      <ul>
        <% dashboard.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

  <div>
    <label><%= t('dashboards.form.tcga_projects') %></label>
    <% @projects.each do |project| %>
      <div>
        <%= check_box_tag "dashboard[projects][]",
            project["id"],
            dashboard.projects.include?(project["id"]),
            id: "dashboard_projects_#{project["id"]}" %>
        <%= label_tag "dashboard_projects_#{project["id"]}",
            "#{project["id"]} — #{project["primary_site"].first}" %>
      </div>
    <% end %>
  </div>

  <div>
    <label><%= t('dashboards.form.visualizations') %></label>
    <% Dashboard::VISUALIZATIONS.each do |viz| %>
      <div>
        <%= check_box_tag "dashboard[visualizations][]",
            viz,
            dashboard.visualizations.include?(viz) %>
        <%= label_tag "dashboard_visualizations_#{viz}",
            Dashboard.visualization_label(viz) %>
      </div>
    <% end %>
  </div>

  <div id="stratify_by_field" style="display: none;">
    <%= form.label :stratify_by, t('dashboards.form.stratify_by') %>
    <%= form.select :stratify_by,
        [
          [t('dashboards.form.stratify_options.gender'), "gender"],
          [t('dashboards.form.stratify_options.tumor_stage'), "tumor_stage"],
          [t('dashboards.form.stratify_options.project_id'), "project_id"]
        ],
        include_blank: t('common.not_selected') %>
  </div>

  <div>
    <%= form.label :top_genes_count %>
    <%= form.number_field :top_genes_count, min: 10, max: 200 %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>

<script>
  function toggleStratify() {
    const field = document.getElementById('stratify_by_field');
    if (!field) return;

    const kmChecked = document.querySelector('input[value="kaplan_meier"]')?.checked;
    field.style.display = kmChecked ? 'block' : 'none';
  }

  document.addEventListener('DOMContentLoaded', toggleStratify);

  document.querySelectorAll('input[name="dashboard[visualizations][]"]')
          .forEach(cb => cb.addEventListener('change', toggleStratify));
</script>